<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_yarooms_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastrar Sala"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastre as salas disponíveis da escola"
            android:textColor="#E5C78B"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNomeSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome da sala"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#C5A059"
            app:hintTextColor="#E5C78B">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNomeSala"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textColorHint="#E5C78B" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutBlocoSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bloco ou localização"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#C5A059"
            app:hintTextColor="#E5C78B">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editBlocoSala"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textColorHint="#E5C78B" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutCapacidadeSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Capacidade"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#C5A059"
            app:hintTextColor="#E5C78B">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editCapacidadeSala"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#E5C78B" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutRecursosSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Recursos separados por vírgula"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#C5A059"
            app:hintTextColor="#E5C78B">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRecursosSala"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:gravity="top"
                android:textColor="#FFFFFF"
                android:textColorHint="#E5C78B" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/textoErroSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF8080"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/botaoSalvarSala"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Salvar sala"
            android:textAllCaps="false"
            android:textColor="#0D2244"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:backgroundTint="#C5A059" />

        <TextView
            android:id="@+id/textoVoltarSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textColor="#E5C78B"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</ScrollView>