<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/yarooms_blue_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tituloAgendamento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOVO AGENDAMENTO"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="@color/yarooms_gold"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="40dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColorHint="@color/gray_text"
            app:hintTextColor="@color/yarooms_gold"
            app:boxStrokeColor="@color/yarooms_gold"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editSala"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/white"
                android:hint="Nome da sala" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoData"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="📅 Selecionar Data"
            android:textColor="@color/white"
            app:backgroundTint="@color/yarooms_blue_light"
            app:strokeColor="@color/yarooms_gold"
            app:strokeWidth="1dp"
            android:layout_marginTop="16dp"
            app:cornerRadius="8dp"/>

        <TextView
            android:id="@+id/textoDataSelecionada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nenhuma data selecionada"
            android:textColor="@color/gray_text"
            android:layout_gravity="center"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoHorario"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="⏰ Selecionar Horário"
            android:textColor="@color/white"
            app:backgroundTint="@color/yarooms_blue_light"
            app:strokeColor="@color/yarooms_gold"
            app:strokeWidth="1dp"
            android:layout_marginTop="16dp"
            app:cornerRadius="8dp"/>

        <TextView
            android:id="@+id/textoHorarioSelecionado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nenhum horário selecionado"
            android:textColor="@color/gray_text"
            android:layout_gravity="center"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoAgendar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CONFIRMAR AGENDAMENTO"
            android:textColor="@color/yarooms_blue_dark"
            android:textStyle="bold"
            android:textSize="16sp"
            app:backgroundTint="@color/yarooms_gold"
            app:cornerRadius="8dp"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>