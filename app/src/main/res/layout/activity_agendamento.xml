<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#1A237E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tituloAgendamento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Novo Agendamento"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:hint="Nome da sala"
            app:hintTextColor="#90CAF9"
            app:boxBackgroundColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editSala"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="#000000" />

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/botaoData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 Selecionar Data"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/textoDataSelecionada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nenhuma data selecionada"
            android:textColor="#90CAF9"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/botaoHorario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏰ Selecionar Horário"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/textoHorarioSelecionado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nenhum horário selecionado"
            android:textColor="#90CAF9"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/botaoAgendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agendar"
            android:backgroundTint="#0D47A1"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>