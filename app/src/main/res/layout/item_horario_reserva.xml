<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardHorario"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/yarooms_gold"
    app:cardBackgroundColor="@color/yarooms_blue_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textoPeriodoHorario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1ª aula"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoHoraHorario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="07:00 às 07:50"
            android:textColor="@color/yarooms_gold_light"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/textoStatusHorario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Disponível"
            android:textColor="@color/yarooms_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>