<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirme seu E-mail"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/textoEmailEnviado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enviando código..."
        android:textAlignment="center"
        android:textSize="16sp"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutCodigo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Código de 6 dígitos">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editCodigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="6"
            android:textSize="24sp"
            android:textAlignment="center"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/textoErroCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚠️ Código inválido"
        android:textColor="#F44336"
        android:visibility="gone"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/botaoConfirmarCodigo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirmar Código"
        android:padding="12dp"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/textoExpiracaoCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱ O código expira em 10:00"
        android:layout_marginTop="16dp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/botaoReenviarCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reenviar Código"
        android:textColor="#1976D2"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/textoVoltarEsqueci"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voltar ao Login"
        android:textColor="#757575"
        android:layout_marginTop="16dp"
        android:padding="8dp"/>

</LinearLayout>