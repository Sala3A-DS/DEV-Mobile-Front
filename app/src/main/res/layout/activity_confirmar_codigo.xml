<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/yarooms_blue_dark"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VERIFICAÇÃO"
        android:textSize="24sp"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        android:textColor="@color/yarooms_gold"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/textoEmailEnviado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enviando código..."
        android:textAlignment="center"
        android:textSize="15sp"
        android:textColor="@color/gray_text"
        android:layout_marginBottom="40dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutCodigo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="@color/gray_text"
        app:hintTextColor="@color/yarooms_gold"
        app:boxStrokeColor="@color/yarooms_gold"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editCodigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="6"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.5"
            android:textAlignment="center"
            android:hint="000000"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/textoErroCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚠️ Código inválido"
        android:textColor="#FF5252"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:textStyle="bold"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/botaoConfirmarCodigo"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CONFIRMAR CÓDIGO"
        android:textColor="@color/yarooms_blue_dark"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        android:backgroundTint="@color/yarooms_gold"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/textoExpiracaoCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱ O código expira em 10:00"
        android:textColor="@color/gray_text"
        android:layout_marginTop="24dp"
        android:textSize="14sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/botaoReenviarCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Não recebeu? Reenviar Código"
        android:textColor="@color/yarooms_gold"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/textoVoltarEsqueci"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voltar ao Login"
        android:textColor="@color/yarooms_gold_light"
        android:layout_marginTop="16dp"
        android:padding="8dp"/>

</LinearLayout>