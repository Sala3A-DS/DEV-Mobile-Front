<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@drawable/bg_yarooms_gradient"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VERIFICAÇÃO"
        android:textSize="24sp"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        android:textColor="@color/yarooms_gold"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/textoEmailEnviado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enviamos um código para seu e-mail"
        android:textAlignment="center"
        android:textSize="15sp"
        android:textColor="@color/gray_text"
        android:layout_marginBottom="40dp" />

    <LinearLayout
        android:id="@+id/layoutCamposCodigo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/editCodigo1"
            android:layout_width="46dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:background="@drawable/bg_codigo_box" />

        <EditText
            android:id="@+id/editCodigo2"
            android:layout_width="46dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:background="@drawable/bg_codigo_box" />

        <EditText
            android:id="@+id/editCodigo3"
            android:layout_width="46dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:background="@drawable/bg_codigo_box" />

        <EditText
            android:id="@+id/editCodigo4"
            android:layout_width="46dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:background="@drawable/bg_codigo_box" />

        <EditText
            android:id="@+id/editCodigo5"
            android:layout_width="46dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:background="@drawable/bg_codigo_box" />

        <EditText
            android:id="@+id/editCodigo6"
            android:layout_width="46dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:background="@drawable/bg_codigo_box" />

    </LinearLayout>

    <TextView
        android:id="@+id/textoErroCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚠️ Código inválido"
        android:textColor="#FF5252"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/botaoConfirmarCodigo"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CONFIRMAR CÓDIGO"
        android:textColor="@color/yarooms_blue_dark"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        android:backgroundTint="@color/yarooms_gold"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/textoExpiracaoCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱ O código expira em 01:00"
        android:textColor="@color/gray_text"
        android:layout_marginTop="24dp"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/botaoReenviarCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Não recebeu? Reenviar Código"
        android:textColor="@color/yarooms_gold"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:padding="8dp" />

</LinearLayout>