<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_yarooms_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Minhas Reservas"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Consulte e cancele suas reservas de salas."
            android:textColor="@color/yarooms_gold_light"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp" />

        <TextView
            android:id="@+id/textoErroMinhasReservas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF8080"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <ListView
            android:id="@+id/listaMinhasReservas"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:background="@color/yarooms_blue_light"
            android:divider="@color/yarooms_blue_dark"
            android:dividerHeight="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoAtualizarReservas"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Atualizar"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/yarooms_blue_dark"
            android:backgroundTint="@color/yarooms_gold"
            app:cornerRadius="8dp"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/textoVoltarMinhasReservas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textColor="@color/yarooms_gold_light"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>