<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_yarooms_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/logoHome"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:layout_gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/textoBemVindo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bem-vindo,"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/yarooms_gold"
            android:layout_gravity="center"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/textoNomeUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuário"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_gravity="center"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/textoCargoUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Professor(a)"
            android:textSize="15sp"
            android:textColor="@color/gray_text"
            android:layout_gravity="center"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/yarooms_gold"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="O que deseja fazer?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoReservarSala"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Reservar sala"
            android:textAllCaps="false"
            android:textColor="@color/yarooms_blue_dark"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/yarooms_gold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoMinhasReservas"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Minhas reservas"
            android:textAllCaps="false"
            android:textColor="@color/yarooms_blue_dark"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/yarooms_gold_light"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoSairProfessor"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Sair"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            android:backgroundTint="#8B1E1E"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>