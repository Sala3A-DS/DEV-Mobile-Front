<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/yarooms_blue_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/logoHome"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/textoBemVindo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BEM-VINDO,"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/yarooms_gold"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/textoNomeUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carregando..."
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"/>

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/yarooms_gold"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEUS AGENDAMENTOS"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="@color/gray_text"
            android:layout_marginBottom="12dp"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="300dp"
            android:background="@color/yarooms_blue_light"
            android:padding="8dp">

            <ListView
                android:id="@+id/listaHomeAgendamentos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@color/yarooms_blue_light"
                android:dividerHeight="1dp"
                android:scrollbars="none"/>
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoNovoAgendamento"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="+ NOVO AGENDAMENTO"
            android:textColor="@color/yarooms_blue_dark"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/yarooms_gold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>