<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_yarooms_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reservar Sala"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecione o espaço, informe a turma e escolha um horário disponível."
            android:textColor="@color/yarooms_gold_light"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp" />

        <!-- CARD DE SELEÇÃO DE ESPAÇO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/yarooms_blue_light"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/yarooms_gold"
            app:strokeWidth="1dp"
            android:layout_marginBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Espaço disponível"
                    android:textColor="@color/yarooms_gold"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerSalas"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@color/yarooms_blue_dark"
                    android:padding="10dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CAMPO DATA -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDataReserva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Data da reserva"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/yarooms_gold"
            app:hintTextColor="@color/yarooms_gold_light"
            android:layout_marginBottom="18dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editDataReserva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:textColor="@color/white"
                android:textColorHint="@color/yarooms_gold_light"
                android:hint="Toque para selecionar a data" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- CAMPO TURMA -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutTurmaReserva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Turma que usará o espaço"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/yarooms_gold"
            app:hintTextColor="@color/yarooms_gold_light"
            android:layout_marginBottom="18dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTurmaReserva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/white"
                android:textColorHint="@color/yarooms_gold_light"
                android:hint="Ex: 3A - DS" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoConsultarDisponibilidade"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Atualizar disponibilidade"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/yarooms_blue_dark"
            android:backgroundTint="@color/yarooms_gold"
            app:cornerRadius="8dp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/textoErroReserva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF8080"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/textoTituloHorarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Horários disponíveis"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:visibility="gone"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp" />

        <ListView
            android:id="@+id/listaHorariosDisponiveis"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:background="@color/yarooms_blue_light"
            android:divider="@color/yarooms_blue_dark"
            android:dividerHeight="8dp"
            android:padding="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textoVoltarReserva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textColor="@color/yarooms_gold_light"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>