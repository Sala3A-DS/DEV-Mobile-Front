<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardMinhaSala"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/yarooms_blue_light"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/yarooms_gold"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textoNomeEspaco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Laboratório de Informática"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoLocalizacaoSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Localização: Bloco A"
            android:textColor="@color/yarooms_gold_light"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/textoNumeroSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Número da sala: 12"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/textoStatusSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Ativa"
            android:textColor="@color/yarooms_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>