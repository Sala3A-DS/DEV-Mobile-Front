<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_yarooms_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textoTituloDiretor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Painel do Diretor"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="32dp" />

        <TextView
            android:id="@+id/textoNomeDiretor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Olá, Diretor"
            android:textColor="#E5C78B"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/textoDescricaoDiretor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gerencie as salas disponíveis da escola."
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/botaoCadastrarSala"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Cadastrar sala"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#0D2244"
            android:backgroundTint="#C5A059" />

        <Button
            android:id="@+id/botaoMinhasSalas"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Minhas salas"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#0D2244"
            android:backgroundTint="#E5C78B"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/botaoAgendamentosGerais"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Agendamentos gerais"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#0D2244"
            android:backgroundTint="#C5A059"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoSairDiretor"
            android:layout_width="180dp"
            android:layout_height="48dp"
            android:text="Sair"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#8B1E1E"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/botaoInfoApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ⓘ"
            android:textSize="26sp"
            android:textColor="@color/yarooms_gold_light"
            android:layout_gravity="center"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>